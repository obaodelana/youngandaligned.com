---
import { getCollection } from 'astro:content';
const features = (await getCollection('features')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const meta = features.find((f) => f.data.eyebrow)?.data;
---

<section class="relative py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="reveal max-w-3xl mx-auto mb-14 lg:mb-20 text-center">
      <p class="eyebrow mb-5">{meta?.eyebrow}</p>
      <h2 class="font-display text-4xl lg:text-5xl text-ink leading-tight text-balance">
        {meta?.heading}<br />
        <span class="text-ink-soft/70">{meta?.intro}</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-5 lg:gap-6">
      {features.map((f, i) => (
        <article class={`reveal reveal-delay-${(i % 3) + 1} ${f.data.span} relative p-7 lg:p-9 bg-marble border border-stone-deep/40 rounded-[3px] group transition-all duration-500 hover:border-brand/50 hover:bg-plaster text-center`}>
          <div class="flex items-center justify-center gap-4 mb-7">
            <span class="number-tag">{`0${i + 1}`}</span>
            <span class="w-10 h-10 rounded-full border border-stone-deep/60 flex items-center justify-center text-brand-deep group-hover:border-brand group-hover:text-brand transition-colors duration-500">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={f.data.icon}/></svg>
            </span>
          </div>
          <p class="font-mono text-[10px] tracking-wide2 uppercase text-brand-deep mb-3">{f.data.tag}</p>
          <h3 class="font-display text-2xl lg:text-[28px] text-ink leading-tight mb-4">{f.data.title}</h3>
          <p class="text-[16px] lg:text-[17px] text-ink-soft leading-[1.7]">{f.data.desc}</p>
        </article>
      ))}
    </div>

  </div>
</section>