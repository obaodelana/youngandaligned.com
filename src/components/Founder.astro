---
import { getCollection } from 'astro:content';
import { AWAKEN_URL } from '../consts';
const ctaHref = AWAKEN_URL;
const entries = await getCollection('founder');
const f = entries[0].data;
---

<section id="founder" class="relative py-24 lg:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <div class="lg:col-span-5 lg:sticky lg:top-24">
        <div class="reveal relative">
          <div class="relative aspect-[4/5] rounded-[3px] overflow-hidden bg-stone vignette">
            <img src={f.image} alt="Bimbo Ogunsola, founder of Young and Aligned" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/15 to-transparent"></div>
          </div>
          <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 bg-plaster border border-stone-deep/50 px-5 py-3 rounded-[2px] whitespace-nowrap">
            <p class="font-display text-base text-ink">Bimbo Ogunsola</p>
            <p class="font-mono text-[10px] tracking-wide2 uppercase text-brand-deep mt-0.5">Founder, Young & Aligned</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 max-w-2xl">
        <div class="reveal mb-8">
          <p class="eyebrow mb-5">{f.eyebrow}</p>
          <h2 class="font-display text-4xl lg:text-[44px] text-ink leading-[1.05] text-balance">
            {f.heading}
          </h2>
        </div>

        <div class="reveal reveal-delay-1 space-y-6 text-[16px] lg:text-[17px] text-ink-soft leading-[1.7]">
          {f.paragraphs.map((p) => (
            <p set:html={p} />
          ))}
        </div>

        <div class="reveal reveal-delay-2 my-10 py-8 pl-6 border-l-2 border-brand">
          <p class="font-display text-2xl lg:text-[28px] text-ink leading-[1.25] text-balance mb-2">
            {f.pullQuote}
          </p>
          <p class="text-base text-ink-soft italic">{f.pullSub}</p>
        </div>

        <div class="reveal reveal-delay-3 flex flex-wrap items-center gap-4">
          <a href={ctaHref} class="btn-primary group inline-flex items-center gap-2.5 px-6 py-3.5 rounded-full text-sm font-medium tracking-wide">
            <span>Join Awaken</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-500 group-hover:translate-x-1"><path d="M1 7h12m0 0L7 1m6 6L7 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/bio" class="link-underline text-sm text-ink-soft hover:text-ink font-medium">Read Bimbo&rsquo;s full bio</a>
        </div>
      </div>

    </div>
  </div>
</section>