---
const stages = [
  {
    num: '01',
    name: 'Awaken',
    tag: 'Understand yourself',
    desc: 'The entry point. Name where you actually are. An identity audit, not a personality test.',
    active: true,
  },
  {
    num: '02',
    name: 'Transform',
    tag: 'Shift how you think',
    desc: 'Reframe the patterns running your decisions. Move from reaction to intention.',
    active: false,
  },
  {
    num: '03',
    name: 'Master',
    tag: 'Take intentional action',
    desc: 'Build the daily rhythm that carries clarity into your relationships, work, and direction.',
    active: false,
  },
];
---

<section id="framework" class="relative py-24 lg:py-32 bg-marble">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="reveal max-w-3xl mb-16 lg:mb-20">
      <p class="eyebrow mb-5">The Young & Aligned Framework</p>
      <h2 class="font-display text-4xl lg:text-5xl text-ink leading-tight text-balance">
        Three stages. One direction.<br />
        <span class="text-ink-soft/70">You start with Awaken.</span>
      </h2>
      <p class="mt-6 text-lg text-ink-soft leading-relaxed max-w-xl">
        A structured system that helps you understand yourself, shift how you think, and take intentional action in your daily life.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-px bg-stone-deep/40 border border-stone-deep/40 rounded-[2px] overflow-hidden">
      {stages.map((s) => (
        <article class={`reveal relative p-8 lg:p-10 ${s.active ? 'bg-plaster' : 'bg-marble/60'}`}>
          <div class="flex items-center justify-between mb-8">
            <span class="number-tag">{s.num}</span>
            {s.active && (
              <span class="font-mono text-[10px] tracking-wide2 uppercase text-brand border border-brand/40 px-2 py-1 rounded-full">Start here</span>
            )}
          </div>
          <h3 class={`font-display text-3xl lg:text-4xl mb-2 ${s.active ? 'text-ink' : 'text-ink-soft/60'}`}>{s.name}</h3>
          <p class={`font-mono text-xs tracking-wide2 uppercase mb-5 ${s.active ? 'text-brand-deep' : 'text-ink-soft/40'}`}>{s.tag}</p>
          <p class={`text-[15px] leading-relaxed ${s.active ? 'text-ink-soft' : 'text-ink-soft/55'}`}>{s.desc}</p>

          {s.active && (
            <div class="absolute top-0 left-0 right-0 h-[2px] bg-brand animate-line-grow"></div>
          )}
        </article>
      ))}
    </div>

  </div>
</section>