---
import { getCollection } from 'astro:content';
import { AWAKEN_URL } from '../consts';
const ctaHref = AWAKEN_URL;

const heroEntries = await getCollection('hero');
const hero = heroEntries[0].data;
---

<section id="top" class="relative pt-28 pb-20 lg:pt-36 lg:pb-28 overflow-hidden grain">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="hidden sm:block absolute -top-32 -right-40 w-[640px] h-[640px] rounded-full bg-brand-soft/20 blur-3xl"></div>
    <div class="hidden sm:block absolute -bottom-40 -left-32 w-[480px] h-[480px] rounded-full bg-jade/10 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <div class="lg:col-span-7 max-w-2xl">
        <div class="reveal flex items-center gap-3 mb-7">
          <span class="block w-8 h-px bg-brand"></span>
          <span class="eyebrow">{hero.eyebrow}</span>
        </div>

        <h1 class="reveal reveal-delay-1 font-display text-[34px] xs:text-[40px] sm:text-6xl lg:text-[78px] leading-[1.05] xs:leading-[0.98] text-ink text-balance">
          {hero.heading}
        </h1>

        <p class="reveal reveal-delay-2 mt-7 text-lg lg:text-xl text-ink-soft leading-relaxed max-w-xl text-pretty" set:html={hero.subtitle.replace('3-month', '<span class="text-brand font-semibold">3-month</span>').replace('18–25', '<span class="text-brand font-semibold">18–25</span>')}></p>

        <div class="reveal reveal-delay-3 mt-10 flex flex-wrap items-center gap-4">
          <a href={ctaHref} class="btn-primary group inline-flex items-center gap-2.5 px-7 py-3.5 rounded-full text-sm font-medium tracking-wide">
            <span>Join Awaken</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-500 group-hover:translate-x-1"><path d="M1 7h12m0 0L7 1m6 6L7 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="#framework" class="btn-ghost inline-flex items-center gap-2 px-6 py-3.5 rounded-full text-sm font-medium">
            See the framework
          </a>
        </div>

        <div class="reveal reveal-delay-4 mt-12 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-ink-soft/70">
          <span class="font-mono text-[11px] tracking-wide2 uppercase">For</span>
          {hero.audience.map((item, i) => (
            <>
              {i > 0 && <span class="w-1 h-1 rounded-full bg-stone-deep"></span>}
              <span>{item}</span>
            </>
          ))}
        </div>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="reveal reveal-delay-2 relative">
          <div class="relative aspect-[4/5] rounded-[3px] overflow-hidden bg-stone vignette">
            <img src={hero.image} alt="Bimbo Ogunsola, founder of Young and Aligned, leading a clarity session for young adults" class="w-full h-full object-cover animate-slow-pan" loading="eager" width="800" height="1000" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink/20 via-transparent to-transparent"></div>
          </div>

          <div class="absolute left-2 -bottom-5 sm:-left-5 lg:-left-8 lg:-bottom-8 bg-plaster border border-stone-deep/50 px-5 py-4 rounded-[2px] shadow-sm max-w-[200px]">
            <p class="font-mono text-[10px] tracking-wide2 uppercase text-brand-deep mb-1.5">The founder</p>
            <p class="font-display text-base text-ink leading-tight">Bimbo Ogunsola</p>
            <p class="text-xs text-ink-soft/70 mt-1">Workforce Analyst<br />Human Development Strategist</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>