---
import { getCollection } from 'astro:content';
const all = await getCollection('decisions');
const gains = all.filter((e) => e.data.kind === 'gain' && !e.data.isIntro).sort((a, b) => a.data.order - b.data.order);
const forYou = all.filter((e) => e.data.kind === 'for' && !e.data.isIntro).sort((a, b) => a.data.order - b.data.order);
const notForYou = all.filter((e) => e.data.kind === 'notFor' && !e.data.isIntro).sort((a, b) => a.data.order - b.data.order);
const gainsIntro = all.find((e) => e.data.kind === 'gain' && e.data.isIntro)?.data;
const forIntro = all.find((e) => e.data.kind === 'for' && e.data.isIntro)?.data;
const notForIntro = all.find((e) => e.data.kind === 'notFor' && e.data.isIntro)?.data;
---

<section class="relative py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    {/* What you'll gain */}
    <div class="reveal max-w-3xl mb-16 lg:mb-24">
      <p class="eyebrow mb-5">{gainsIntro?.eyebrow}</p>
      <h2 class="font-display text-4xl lg:text-5xl text-ink leading-tight text-balance">
        {gainsIntro?.heading}
      </h2>
    </div>

    <div class="reveal reveal-delay-1 grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-5 mb-24 lg:mb-32">
      {gains.map((g) => (
        <div class="flex items-start gap-3">
          <span class="mt-1.5 flex-shrink-0 w-5 h-5 rounded-full bg-brand/10 flex items-center justify-center">
            <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-brand-deep"/></svg>
          </span>
          <p class="text-[15px] lg:text-base text-ink-soft leading-relaxed">{g.data.text}</p>
        </div>
      ))}
    </div>

    {/* Who this is for / Who this is not for */}
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-12">

      <div class="reveal">
        <div class="border border-stone-deep/40 rounded-[3px] bg-plaster p-7 lg:p-9 h-full">
          <p class="eyebrow text-brand-deep mb-3">Who this is for</p>
          <h3 class="font-display text-2xl lg:text-[28px] text-ink leading-tight mb-7">
            {forIntro?.heading}
          </h3>
          <ul class="space-y-4">
            {forYou.map((f) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 flex-shrink-0 w-5 h-5 rounded-full bg-brand/10 flex items-center justify-center">
                  <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-brand-deep"/></svg>
                </span>
                <p class="text-[15px] lg:text-base text-ink-soft leading-relaxed">{f.data.text}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="reveal reveal-delay-1">
        <div class="border border-stone-deep/40 rounded-[3px] bg-marble p-7 lg:p-9 h-full">
          <p class="eyebrow mb-3" style="color: theme('colors.ink-soft');">Who this is not for</p>
          <h3 class="font-display text-2xl lg:text-[28px] text-ink leading-tight mb-7">
            {notForIntro?.heading}
          </h3>
          <ul class="space-y-4">
            {notForYou.map((n) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 flex-shrink-0 w-5 h-5 rounded-full bg-ink/5 flex items-center justify-center">
                  <svg width="11" height="11" viewBox="0 0 14 14" fill="none"><path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-ink-soft"/></svg>
                </span>
                <p class="text-[15px] lg:text-base text-ink-soft/80 leading-relaxed">{n.data.text}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>

  </div>
</section>