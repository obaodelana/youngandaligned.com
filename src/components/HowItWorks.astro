---
import { getCollection } from 'astro:content';
const steps = (await getCollection('steps')).sort((a, b) => a.data.order - b.data.order);
---

<section class="relative py-24 lg:py-32 bg-ink text-plaster overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: linear-gradient(to right, rgba(245,240,230,1) 1px, transparent 1px); background-size: 14% 100%;"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <div class="reveal max-w-3xl mx-auto mb-20 text-center">
      <p class="eyebrow mb-5" style="color:white;">How Awaken works</p>
      <h2 class="font-display text-[34px] xs:text-[40px] sm:text-5xl lg:text-5xl text-plaster leading-[1.05] xs:leading-tight text-balance">
        Three movements.<br />
        <span class="text-brand-soft/70">Across three months.</span>
      </h2>
    </div>

    <div class="relative max-w-4xl mx-auto">
      <!-- Timeline line -->
      <div class="absolute left-[28px] lg:left-[36px] top-[60px] bottom-[60px] w-[2px] bg-gradient-to-b from-brand/50 via-brand/30 to-brand/10 hidden sm:block"></div>

      <ol class="space-y-20 lg:space-y-28">
        {steps.map((s, i) => (
          <li class="reveal relative grid sm:grid-cols-[72px_1fr] lg:grid-cols-[88px_1fr] gap-8 lg:gap-10 items-start">
            <!-- Numbered badge -->
            <div class="relative flex justify-center sm:block">
              <div class="relative z-10 w-14 h-14 lg:w-[72px] lg:h-[72px] rounded-full border-2 border-brand/60 bg-brand/10 flex items-center justify-center shadow-lg shadow-brand/5">
                <span class="font-mono text-base lg:text-xl text-brand font-semibold tracking-wide">{s.data.num}</span>
              </div>
            </div>

            <!-- Content -->
            <div class="pt-1 lg:pt-2">
              <h3 class="font-display text-[28px] sm:text-[32px] lg:text-[42px] text-plaster mb-5 leading-[1.08] tracking-tight">{s.data.name}</h3>
              <p class="text-base sm:text-lg lg:text-xl text-plaster/80 leading-relaxed mb-3 max-w-2xl">{s.data.desc}</p>
              <div class="flex items-start gap-3">
                <span class="block w-5 h-px bg-brand/40 mt-3 shrink-0"></span>
                <p class="text-sm sm:text-base text-plaster/80 leading-relaxed max-w-lg">{s.data.detail}</p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>