---
import { getCollection } from 'astro:content';
const steps = (await getCollection('steps')).sort((a, b) => a.data.order - b.data.order);
---

<section class="relative py-24 lg:py-32 bg-ink text-plaster overflow-hidden">
  <div class="absolute inset-0 pointer-events-none opacity-[0.04]" style="background-image: linear-gradient(to right, rgba(245,240,230,1) 1px, transparent 1px); background-size: 14% 100%;"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
    <div class="reveal max-w-3xl mb-20">
      <p class="eyebrow mb-5" style="color:#D4B894;">How Awaken works</p>
      <h2 class="font-display text-[34px] xs:text-[40px] sm:text-5xl lg:text-5xl text-plaster leading-[1.05] xs:leading-tight text-balance">
        Three movements.<br />
        <span class="text-brand-soft/70">Across three months.</span>
      </h2>
    </div>

    <div class="relative">
      <div class="absolute left-[42px] lg:left-[60px] top-2 bottom-2 w-px bg-plaster/15 hidden sm:block"></div>

      <ol class="space-y-16 lg:space-y-24">
        {steps.map((s, i) => (
          <li class="reveal grid sm:grid-cols-[88px_1fr] lg:grid-cols-[120px_1fr] gap-6 lg:gap-12 items-start">
            <div class="relative">
              <div class="w-[84px] h-[84px] lg:w-[116px] lg:h-[116px] rounded-full border border-brand/40 flex items-center justify-center bg-ink relative z-10">
                <span class="font-mono text-base lg:text-xl text-brand">{s.data.num}</span>
              </div>
              {i < steps.length - 1 && (
                <div class="absolute left-1/2 top-full w-px h-8 bg-plaster/15 sm:hidden"></div>
              )}
            </div>

            <div class="pt-3 lg:pt-7 max-w-2xl">
              <h3 class="font-display text-3xl lg:text-[40px] text-plaster mb-4 leading-tight">{s.data.name}</h3>
              <p class="text-lg lg:text-xl text-plaster/85 leading-relaxed mb-5 text-pretty">{s.data.desc}</p>
              <p class="text-sm text-brand-soft/70 font-mono tracking-wide leading-relaxed">{s.data.detail}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>