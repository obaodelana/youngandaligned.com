---
const path = Astro.url.pathname;
const isHome = path === '/' || path === '/index' || path === '';
const sectionLinks = [
  { label: 'Awaken', section: 'awaken' },
  { label: 'Framework', section: 'framework' },
  { label: 'About', section: 'founder', path: '/bio' },
];
const links = sectionLinks.map((l) => ({
  label: l.label,
  href: l.path || (isHome ? `#${l.section}` : `/#${l.section}`),
}));
const homeLogoHref = isHome ? '#top' : '/';
const ctaHref = 'https://youngandaligned.fillout.com/awaken';
---

<header class="fixed top-0 inset-x-0 z-50">
  <div class="backdrop-blur-md bg-plaster/80 border-b border-stone-deep/40">
    <nav class="max-w-7xl mx-auto px-6 lg:px-10 h-16 flex items-center justify-between">
      <a href={homeLogoHref} class="group flex items-center gap-3">
        <img src="/images/logos/ya_small.png" alt="" class="h-8 w-8 object-contain rounded-[3px] opacity-90 transition-opacity duration-500 group-hover:opacity-100" />
        <span class="font-display text-lg tracking-tighter text-ink">Young<span class="text-brand-deep"> & </span>Aligned</span>
      </a>

      <div class="hidden md:flex items-center gap-9">
        {links.map((l) => (
          <a href={l.href} class="link-underline font-body text-sm text-ink-soft hover:text-ink transition-colors">{l.label}</a>
        ))}
      </div>

      <a href={ctaHref} class="btn-primary px-5 py-2.5 text-sm font-medium tracking-wide rounded-full hidden sm:inline-flex items-center gap-2">
        <span>Join Awaken</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-500 group-hover:translate-x-0.5"><path d="M1 7h12m0 0L7 1m6 6L7 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>

      <button id="nav-toggle" class="md:hidden p-2 -mr-2" aria-label="Menu">
        <svg width="22" height="14" viewBox="0 0 22 14" fill="none"><path d="M0 1h22M0 7h22M0 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </nav>
  </div>

  <div id="nav-mobile" class="hidden md:hidden bg-plaster border-b border-stone-deep/40 px-6 py-4">
    {links.map((l) => (
      <a href={l.href} class="block py-3 text-ink-soft border-b border-stone/60 last:border-0 font-body">{l.label}</a>
    ))}
    <a href={ctaHref} class="block mt-3 btn-primary text-center py-3 rounded-full text-sm">Join Awaken</a>
  </div>
</header>

<script is:inline>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-mobile')?.classList.toggle('hidden');
  });
</script>