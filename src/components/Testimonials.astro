---
import { getCollection } from 'astro:content';
const entries = (await getCollection('testimonials')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const meta = entries.find((e) => e.data.eyebrow)?.data;
const feature = entries.find((e) => e.data.feature);
const rest = entries.filter((e) => !e.data.feature);
const intimateEntries = await getCollection('intimateTestimonial');
const intimate = intimateEntries[0].data;
---

<section class="relative py-24 lg:py-32 bg-marble">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">

    <div class="reveal max-w-3xl mb-16 lg:mb-20">
      <p class="eyebrow mb-5">{meta?.eyebrow}</p>
      <h2 class="font-display text-4xl lg:text-5xl text-ink leading-tight text-balance">
        {meta?.heading?.split('.')[0]}.<br />
        <span class="text-ink-soft/70">{meta?.heading?.split('.')[1]}.</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-12 gap-5 lg:gap-6">

      <article class="reveal lg:col-span-6 bg-plaster border border-stone-deep/40 p-8 lg:p-10 rounded-[2px]">
        <span class="font-display text-5xl text-brand/40 leading-none block mb-3">"</span>
        <p class="text-base lg:text-[17px] leading-relaxed text-ink-soft italic mb-7">{feature?.data.quote}</p>
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-full bg-jade text-plaster flex items-center justify-center font-display text-sm">{feature?.data.initial}</span>
          <div>
            <p class="text-sm font-medium text-ink">{feature?.data.name}</p>
            <p class="text-xs text-ink-soft/60">{feature?.data.role}</p>
          </div>
        </div>
      </article>

      <div class="lg:col-span-6 grid sm:grid-cols-2 gap-5 lg:gap-6 content-start">
        {rest.map((t, i) => (
          <article class={`reveal reveal-delay-${(i % 2) + 1} bg-plaster border border-stone-deep/40 p-6 lg:p-7 rounded-[2px]`}>
            <span class="font-display text-3xl text-brand/40 leading-none block mb-2">"</span>
            <p class="text-[14px] leading-relaxed text-ink-soft italic mb-5">{t.data.quote}</p>
            <div class="flex items-center gap-2.5">
              <span class="w-8 h-8 rounded-full bg-jade text-plaster flex items-center justify-center font-display text-xs">{t.data.initial}</span>
              <div>
                <p class="text-xs font-medium text-ink">{t.data.name}</p>
                <p class="text-[11px] text-ink-soft/55">{t.data.role}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>

    <div class="reveal mt-6 lg:mt-8 relative bg-ink text-plaster p-8 lg:p-12 rounded-[2px] overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand/60 to-transparent"></div>
      <div class="absolute -right-12 -top-12 w-48 h-48 arabesque-divider opacity-20"></div>
      <div class="relative max-w-2xl">
        <p class="font-mono text-[10px] tracking-wide2 uppercase text-brand-soft mb-5">{intimate.eyebrow}</p>
        <span class="font-display text-5xl text-brand/50 leading-none block mb-4">"</span>
        <p class="font-display text-xl lg:text-2xl leading-[1.35] text-plaster/95 italic mb-7 text-pretty">{intimate.quote}</p>
        <div class="flex items-center gap-3">
          <span class="w-10 h-10 rounded-full bg-brand text-ink flex items-center justify-center font-display text-sm">{intimate.initial}</span>
          <div>
            <p class="text-sm font-medium text-plaster">{intimate.name}</p>
            <p class="text-xs text-plaster/55">On what changed</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>