---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Young and Aligned — Awaken: clarity for young adults of faith',
  description = 'A faith-based clarity experience that helps young adults understand who they are, think more clearly, and move with intention.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/logos/ya_big.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/images/logos/ya_small.png" />
    <link rel="apple-touch-icon" href="/images/logos/ya_big.png" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Hanken+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce) {
          document.documentElement.classList.add('reduce-motion');
          const css = document.createElement('style');
          css.textContent = `.reveal{opacity:1!important;transform:none!important}.animate-slow-pan{animation:none!important}`;
          document.head.appendChild(css);
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        const observe = () => {
          document.querySelectorAll('.reveal:not(.is-visible)').forEach((el) => io.observe(el));
        };
        if (document.readyState !== 'loading') observe();
        else document.addEventListener('DOMContentLoaded', observe);
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <slot />
  </body>
</html>