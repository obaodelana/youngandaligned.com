---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Framework from '../components/Framework.astro';
import AudienceTabs from '../components/AudienceTabs.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WeeklyExpectation from '../components/WeeklyExpectation.astro';
import Features from '../components/Features.astro';
import GainAndFit from '../components/GainAndFit.astro';
import Testimonials from '../components/Testimonials.astro';
import Founder from '../components/Founder.astro';
import Objections from '../components/Objections.astro';
import InvestmentNotice from '../components/InvestmentNotice.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import { SITE_URL, DEFAULT_OG_IMAGE } from '../consts';

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Young and Aligned - Awaken: clarity for young adults of faith',
  url: SITE_URL,
  description:
    'A 3-month faith-based clarity experience for young adults aged 18–25 to understand who they are, think more clearly, and move with intention.',
  isPartOf: { '@type': 'WebSite', name: 'Young & Aligned', url: SITE_URL },
  primaryImageOfPage: { '@type': 'ImageObject', url: DEFAULT_OG_IMAGE },
};
---

<Layout path="/" image={DEFAULT_OG_IMAGE} jsonLd={homeSchema}>
  <Nav />
  <main>
    <Hero />
    <Framework />
    <AudienceTabs />
    <HowItWorks />
    <WeeklyExpectation />
    <Features />
    <GainAndFit />
    <InvestmentNotice />
    <Testimonials />
    <Founder />
    <Objections />
    <FinalCTA />
  </main>
  <Footer />
</Layout>